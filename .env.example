# Supabase (find these in your Supabase dashboard home page)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co   # "Project URL"
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx            # "Publishable key"
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx                     # "Secret key"

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Reddit (optional — app works without these using public JSON endpoints)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ExpertScout/1.0
